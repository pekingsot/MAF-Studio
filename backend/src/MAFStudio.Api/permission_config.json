{
  "AllowAnonymous": [
    "/api/auth/login",
    "/api/auth/register",
    "/api/health",
    "/api/system/environment",
    "/api/index.html",
    "/api/swagger",
    "/api/swagger/*",
    "/",
    "/index.html",
    "/static/*",
    "/favicon.ico"
  ],
  "RequireAuthentication": [
    "/api/*"
  ],
  "RequirePermission": {
    "/api/agents": {
      "GET": "agent:read",
      "POST": "agent:create",
      "PUT": "agent:update",
      "DELETE": "agent:delete"
    },
    "/api/llmconfigs": {
      "GET": "llmconfig:read",
      "POST": "llmconfig:create",
      "PUT": "llmconfig:update",
      "DELETE": "llmconfig:delete"
    },
    "/api/agenttypes": {
      "GET": "agenttype:read",
      "POST": "agenttype:manage",
      "PUT": "agenttype:manage",
      "DELETE": "agenttype:manage"
    },
    "/api/logs": {
      "GET": "log:read"
    },
    "/api/operationlogs": {
      "GET": "log:read"
    },
    "/api/users": {
      "GET": "user:manage",
      "POST": "user:manage",
      "PUT": "user:manage",
      "DELETE": "user:manage"
    },
    "/api/roles": {
      "GET": "user:manage",
      "POST": "user:manage",
      "PUT": "user:manage",
      "DELETE": "user:manage"
    },
    "/api/permissions": {
      "GET": "user:manage",
      "POST": "user:manage",
      "PUT": "user:manage",
      "DELETE": "user:manage"
    },
    "/api/collaborations": {
      "GET": "collaboration:read",
      "POST": "collaboration:manage",
      "PUT": "collaboration:manage",
      "DELETE": "collaboration:manage"
    }
  }
}
