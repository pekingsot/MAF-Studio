# ==================== Agent运行时配置 ====================
AGENT_IDLE_TIMEOUT_MINUTES=30
AGENT_SLEEP_TIMEOUT_MINUTES=60
AGENT_MAX_ACTIVE_AGENTS=100
AGENT_CLEANUP_INTERVAL_MINUTES=5
