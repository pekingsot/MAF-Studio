# ==================== 数据库配置 ====================
POSTGRES_USER=mafuser
POSTGRES_PASSWORD=mafpassword
POSTGRES_DB=mafstudio
POSTGRES_PORT=5432

# ==================== 后端配置 ====================
ASPNETCORE_ENVIRONMENT=Production
BACKEND_PORT=5000

# ==================== 前端配置 ====================
FRONTEND_PORT=80

# ==================== JWT配置 ====================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
